@@ -0,0 +1,204 @@
+// Copyright Azahar Emulator Project
+// Licensed under GPLv2 or any later version
+// Refer to the license.txt file included.
+
+#include "common/serial_sync.h"
+#include "common/logging/log.h"
+
+#ifdef _WIN32
+#include <windows.h>
+#else
+#include <fcntl.h>
+#include <termios.h>
+#include <unistd.h>
+#include <cerrno>
+#include <cstring>
+#endif
+
+namespace Common {
+
+SerialSync3D& SerialSync3D::GetInstance() {
+    static SerialSync3D instance;
+    return instance;
+}
+
+SerialSync3D::~SerialSync3D() {
+    Close();
+}
+
+bool SerialSync3D::Open(const std::string& port_name, int baud_rate) {
+    if (is_open_.load()) {
+        return true;
+    }
+
+    // If port name is empty, sync is disabled (no error).
+    if (port_name.empty()) {
+        return false;  // disabled by configuration
+    }
+    if (baud_rate <= 0) {
+        baud_rate = 115200;
+    }
+
+    const std::string& actual_port = port_name;
+
+    std::lock_guard<std::mutex> lock(send_mutex_);
+
+#ifdef _WIN32
+    HANDLE h = CreateFileA(
+        actual_port.c_str(),
+        GENERIC_WRITE,
+        0,
+        nullptr,
+        OPEN_EXISTING,
+        0,
+        nullptr
+    );
+
+    if (h == INVALID_HANDLE_VALUE) {
+        DWORD err = GetLastError();
+        std::lock_guard<std::mutex> err_lock(error_mutex_);
+        last_error_ = "CreateFileA(" + actual_port + ") failed (error " + std::to_string(err) + ")";
+        LOG_ERROR(Common, "SerialSync3D: {}", last_error_);
+        open_failed_.store(true);
+        return false;
+    }
+
+    DCB dcb{};
+    dcb.DCBlength = sizeof(dcb);
+    if (!GetCommState(h, &dcb)) {
+        std::lock_guard<std::mutex> err_lock(error_mutex_);
+        last_error_ = "GetCommState failed";
+        LOG_ERROR(Common, "SerialSync3D: {}", last_error_);
+        CloseHandle(h);
+        open_failed_.store(true);
+        return false;
+    }
+
+    dcb.BaudRate = static_cast<DWORD>(baud_rate);
+    dcb.ByteSize = 8;
+    dcb.StopBits = ONESTOPBIT;
+    dcb.Parity = NOPARITY;
+    dcb.fRtsControl = RTS_CONTROL_DISABLE;
+    dcb.fDtrControl = DTR_CONTROL_DISABLE;
+
+    if (!SetCommState(h, &dcb)) {
+        std::lock_guard<std::mutex> err_lock(error_mutex_);
+        last_error_ = "SetCommState failed";
+        LOG_ERROR(Common, "SerialSync3D: {}", last_error_);
+        CloseHandle(h);
+        open_failed_.store(true);
+        return false;
+    }
+
+    // Set short timeouts for non-blocking writes.
+    // 1ms timeout prevents stalls if device is disconnected.
+    COMMTIMEOUTS timeouts{};
+    timeouts.WriteTotalTimeoutConstant = 1;
+    timeouts.WriteTotalTimeoutMultiplier = 0;
+    SetCommTimeouts(h, &timeouts);
+
+    handle_ = static_cast<void*>(h);
+#else
+    int fd = ::open(actual_port.c_str(), O_WRONLY | O_NOCTTY | O_NDELAY);
+    if (fd < 0) {
+        std::lock_guard<std::mutex> err_lock(error_mutex_);
+        last_error_ = std::string("open(") + actual_port + ") failed: " + std::strerror(errno);
+        LOG_ERROR(Common, "SerialSync3D: {}", last_error_);
+        open_failed_.store(true);
+        return false;
+    }
+
+    struct termios options;
+    if (tcgetattr(fd, &options) != 0) {
+        std::lock_guard<std::mutex> err_lock(error_mutex_);
+        last_error_ = "tcgetattr failed";
+        LOG_ERROR(Common, "SerialSync3D: {}", last_error_);
+        ::close(fd);
+        open_failed_.store(true);
+        return false;
+    }
+
+    speed_t speed = B115200;
+    switch (baud_rate) {
+    case 9600:   speed = B9600; break;
+    case 19200:  speed = B19200; break;
+    case 38400:  speed = B38400; break;
+    case 57600:  speed = B57600; break;
+    case 115200: speed = B115200; break;
+    default:     speed = B115200; break;
+    }
+
+    cfsetispeed(&options, speed);
+    cfsetospeed(&options, speed);
+    options.c_cflag |= (CLOCAL | CREAD);
+    options.c_cflag &= ~PARENB;
+    options.c_cflag &= ~CSTOPB;
+    options.c_cflag &= ~CSIZE;
+    options.c_cflag |= CS8;
+    options.c_lflag &= ~(ICANON | ECHO | ECHOE | ISIG);
+    options.c_iflag &= ~(IXON | IXOFF | IXANY);
+    options.c_oflag &= ~OPOST;
+
+    if (tcsetattr(fd, TCSANOW, &options) != 0) {
+        std::lock_guard<std::mutex> err_lock(error_mutex_);
+        last_error_ = "tcsetattr failed";
+        LOG_ERROR(Common, "SerialSync3D: {}", last_error_);
+        ::close(fd);
+        open_failed_.store(true);
+        return false;
+    }
+
+    handle_ = reinterpret_cast<void*>(static_cast<intptr_t>(fd));
+#endif
+
+    is_open_.store(true);
+    open_failed_.store(false);
+    LOG_INFO(Common, "SerialSync3D: Opened {} at {} baud for 3D sync", actual_port, baud_rate);
+    return true;
+}
+
+void SerialSync3D::Close() {
+    if (!is_open_.load()) {
+        return;
+    }
+
+    std::lock_guard<std::mutex> lock(send_mutex_);
+
+#ifdef _WIN32
+    if (handle_) {
+        CloseHandle(static_cast<HANDLE>(handle_));
+    }
+#else
+    if (handle_) {
+        int fd = static_cast<int>(reinterpret_cast<intptr_t>(handle_));
+        ::close(fd);
+    }
+#endif
+    handle_ = nullptr;
+    is_open_.store(false);
+    LOG_INFO(Common, "SerialSync3D: Closed serial port");
+}
+
+void SerialSync3D::SendEyeSignal(bool is_right_eye) {
+    if (!is_open_.load() || !handle_) {
+        return;
+    }
+
+    const char cmd = is_right_eye ? 'R' : 'L';
+
+#ifdef _WIN32
+    DWORD written = 0;
+    WriteFile(static_cast<HANDLE>(handle_), &cmd, 1, &written, nullptr);
+#else
+    int fd = static_cast<int>(reinterpret_cast<intptr_t>(handle_));
+    ssize_t n = ::write(fd, &cmd, 1);
+    (void)n;
+#endif
+}
+
+std::string SerialSync3D::GetLastError() const {
+    std::lock_guard<std::mutex> lock(error_mutex_);
+    return last_error_;
+}
+
+} // namespace Common

+void RendererOpenGL::DoPageFlipPresent(const Layout::FramebufferLayout& layout,
+                                       bool is_right_eye) {
+    using Common::SerialSync3D;
+
+    // Lazy-init serial port on first page-flip frame
+    if (!pageflip_serial_ready_) {
+        const std::string& port_name = Settings::values.pageflip_serial_port.GetValue();
+        const int baud = Settings::values.pageflip_serial_baud.GetValue();
+        if (!port_name.empty()) {
+            pageflip_serial_ready_ = SerialSync3D::GetInstance().Open(port_name, baud);
+        } else {
+            pageflip_serial_ready_ = true;  // disabled, mark ready so we don't spam log
+        }
+    }
+
+    // Send sync signal to Arduino BEFORE rendering, so IR fires just before VSync.
+    SerialSync3D::GetInstance().SendEyeSignal(is_right_eye);
+
+    // Update state for DrawScreens to pick correct eye
+    pageflip_current_eye_ = is_right_eye;
+    pageflip_frame_count_++;
+
+    // Render to mailbox. The mailbox's GetRenderFrame() will wait for the
+    // previous present to complete, naturally pacing us to 120Hz.
+    RenderToMailbox(layout, render_window.mailbox, /*flipped=*/false);
+
+    // Force GPU to finish commands before the next present.
+    // This ensures tight vsync-aligned timing.
+    glFinish();
+}

+// Copyright Azahar Emulator Project
+// Licensed under GPLv2 or any later version
+// Refer to the license.txt file included.
+
+#pragma once
+
+#include <atomic>
+#include <mutex>
+#include <string>
+
+namespace Common {
+
+/**
+ * Cross-platform serial port for 3D IR emitter sync.
+ * Used by Active Shutter 3D glasses (Xpand / NVIDIA 3D Vision / DLP Link compatible).
+ *
+ * Sends a single byte ('L' or 'R') before each page-flip frame so the
+ * external Arduino IR emitter can fire sync pulses to the 3D glasses.
+ *
+ * Thread-safe.
+ *
+ * Usage:
+ *   auto& sync = SerialSync3D::GetInstance();
+ *   sync.Open("COM3", 115200);        // optional: opens at startup
+ *   sync.SendEyeSignal(false);         // send 'L' for left-eye frame
+ *   sync.SendEyeSignal(true);          // send 'R' for right-eye frame
+ *   sync.Close();                      // optional: closes at shutdown
+ */
+class SerialSync3D {
+public:
+    /// Get the global singleton instance.
+    static SerialSync3D& GetInstance();
+
+    /// Open the serial port. Returns true on success, false on failure.
+    /// If port_name is empty, uses the value from settings (pageflip_serial_port).
+    /// If already open, returns true immediately.
+    bool Open(const std::string& port_name = "", int baud_rate = 0);
+
+    /// Close the serial port.
+    void Close();
+
+    /// Send a sync signal for the given eye.
+    /// is_right_eye = false -> 'L', true -> 'R'
+    /// No-op if the port isn't open or disabled by empty port name.
+    void SendEyeSignal(bool is_right_eye);
+
+    /// Check if the port is currently open.
+    bool IsOpen() const { return is_open_.load(); }
+
+    /// Get the last error message (empty if no error).
+    std::string GetLastError() const;
+
+private:
+    SerialSync3D() = default;
+    ~SerialSync3D();
+
+    SerialSync3D(const SerialSync3D&) = delete;
+    SerialSync3D& operator=(const SerialSync3D&) = delete;
+
+    // Platform-specific handle.
+    // Windows: HANDLE (cast through void*)
+    // POSIX:   int fd (cast through intptr_t)
+    void* handle_ = nullptr;
+
+    std::atomic<bool> is_open_{false};
+    std::atomic<bool> open_failed_{false};
+    mutable std::mutex send_mutex_;
+    mutable std::mutex error_mutex_;
+    std::string last_error_;
+};
+
+} // namespace Common
